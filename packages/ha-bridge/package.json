{
  "name": "@maison-3d/ha-bridge",
  "version": "0.1.0",
  "description": "Home Assistant WebSocket bridge for Maison 3D fork",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "dependencies": {
    "home-assistant-js-websocket": "^9.5.0",
    "zustand": "^5"
  },
  "devDependencies": {
    "@pascal/typescript-config": "*",
    "@types/react": "^19.2.2",
    "typescript": "5.9.3"
  }
}
